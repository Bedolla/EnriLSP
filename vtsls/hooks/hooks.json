{
  "description": "Check for vtsls installation on init",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/check-vtsls.ps1\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}

{
  "astro-language-server": {
    "command": "powershell.exe",
    "args": [
      "-NoLogo",
      "-NoProfile",
      "-NonInteractive",
      "-ExecutionPolicy",
      "Bypass",
      "-Command",
      "$ErrorActionPreference='Stop';$ProgressPreference='SilentlyContinue';$proxy=[IO.Path]::Combine($env:LOCALAPPDATA,'EnriLSP','bin','enrilsp-lsp-proxy.ps1');$server=[IO.Path]::Combine($env:APPDATA,'npm','astro-ls.cmd');$tsdk=[IO.Path]::Combine($env:APPDATA,'npm','node_modules','typescript','lib');for($i=0;$i -lt 480 -and -not (Test-Path $server);$i++){Start-Sleep -Milliseconds 250};if(-not (Test-Path $server)){exit 127};if(Test-Path $tsdk){$env:ENRILSP_TSDK_PATH=$tsdk};if(Test-Path $proxy){& $proxy $server '--stdio'}else{& $server '--stdio'}"
    ],
    "extensionToLanguage": {
      ".astro": "astro"
    }
  }
}

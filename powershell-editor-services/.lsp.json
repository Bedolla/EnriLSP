{
  "powershell-editor-services": {
    "command": "pwsh",
    "args": [
      "-NoLogo",
      "-NoProfile",
      "-ExecutionPolicy",
      "Bypass",
      "-File",
      "$env:LOCALAPPDATA/PowerShellEditorServices/PowerShellEditorServices/Start-EditorServices.ps1",
      "-HostName",
      "Claude Code",
      "-HostProfileId",
      "claude",
      "-HostVersion",
      "1.0.0",
      "-BundledModulesPath",
      "$env:LOCALAPPDATA/PowerShellEditorServices/PowerShellEditorServices",
      "-Stdio"
    ],
    "extensionToLanguage": {
      ".ps1": "powershell",
      ".psm1": "powershell",
      ".psd1": "powershell"
    }
  }
}

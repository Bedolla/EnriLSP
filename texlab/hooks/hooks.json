{
  "description": "Check for texlab installation on init",
  "hooks": {
    "Setup": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/check-texlab.ps1\"",
            "timeout": 300
          }
        ]
      }
    ]
  }
}

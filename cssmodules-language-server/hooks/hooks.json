{
  "description": "Check for cssmodules-language-server installation on init",
  "hooks": {
    "Setup": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/check-cssmodules-language-server.ps1\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}

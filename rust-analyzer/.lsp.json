{
  "rust-analyzer": {
    "command": "pwsh",
    "args": [
      "-NoLogo",
      "-NoProfile",
      "-NonInteractive",
      "-ExecutionPolicy",
      "Bypass",
      "-Command",
      "$ErrorActionPreference='Stop';$ProgressPreference='SilentlyContinue';$proxy=$null;$proxyCandidate=$null;if($env:CLAUDE_PLUGIN_ROOT){$proxyCandidate=[IO.Path]::Combine($env:CLAUDE_PLUGIN_ROOT,'hooks','enrilsp-lsp-proxy.ps1');if(Test-Path $proxyCandidate){$proxy=$proxyCandidate}};if(-not $proxy){$proxyCandidate=[IO.Path]::Combine($env:LOCALAPPDATA,'EnriLSP','bin','enrilsp-lsp-proxy.ps1');if(Test-Path $proxyCandidate){$proxy=$proxyCandidate}};if(-not $proxy){$proxyCandidate=[IO.Path]::Combine((Get-Location).Path,'hooks','enrilsp-lsp-proxy.ps1');if(Test-Path $proxyCandidate){$proxy=$proxyCandidate}};$server=$null;$paths=@([IO.Path]::Combine($env:APPDATA,'Rust','cargo','bin','rust-analyzer.exe'),[IO.Path]::Combine($env:APPDATA,'Rust','rustup','toolchains','stable-x86_64-pc-windows-msvc','bin','rust-analyzer.exe'),[IO.Path]::Combine($env:APPDATA,'Rust','rustup','toolchains','stable-x86_64-pc-windows-gnu','bin','rust-analyzer.exe'),[IO.Path]::Combine($env:USERPROFILE,'.cargo','bin','rust-analyzer.exe'),[IO.Path]::Combine($env:USERPROFILE,'.rustup','toolchains','stable-x86_64-pc-windows-msvc','bin','rust-analyzer.exe'),[IO.Path]::Combine($env:USERPROFILE,'.rustup','toolchains','stable-x86_64-pc-windows-gnu','bin','rust-analyzer.exe'));for($i=0;$i -lt 480 -and -not $server;$i++){foreach($p in $paths){if(Test-Path $p){$server=$p;break}};if(-not $server){$cmd=Get-Command rust-analyzer -ErrorAction SilentlyContinue;if($cmd -and $cmd.Source){$server=$cmd.Source}};if(-not $server){Start-Sleep -Milliseconds 250}};if(-not $server){exit 127};if(Test-Path $proxy){& $proxy $server}else{& $server}"
    ],
    "extensionToLanguage": {
      ".rs": "rust"
    }
  }
}

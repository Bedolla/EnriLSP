{
  "description": "Check for gopls installation on init",
  "hooks": {
    "Setup": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/check-gopls.ps1\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}

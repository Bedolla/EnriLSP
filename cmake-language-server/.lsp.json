{
  "cmake-language-server": {
    "command": "powershell.exe",
    "args": [
      "-NoLogo",
      "-NoProfile",
      "-NonInteractive",
      "-ExecutionPolicy",
      "Bypass",
      "-Command",
      "$ErrorActionPreference='Stop';$ProgressPreference='SilentlyContinue';$server=[IO.Path]::Combine($env:LOCALAPPDATA,'EnriLSP','cmake-language-server','.venv','Scripts','cmake-language-server.exe');for($i=0;$i -lt 480 -and -not (Test-Path $server);$i++){Start-Sleep -Milliseconds 250};if(-not (Test-Path $server)){exit 127};& $server"
    ],
    "extensionToLanguage": {
      ".cmake": "cmake"
    }
  }
}
